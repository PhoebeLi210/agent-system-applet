<!-- 签名模态框 -->
<view wx:if="{{showSignaturePad}}" class="modal-overlay" bindtap="closeSignaturePad"></view>
<view wx:if="{{showSignaturePad}}" class="modal-container signature-container">
  <view class="modal-header">
    <text class="modal-title">电子协议</text>
    <text class="modal-close" bindtap="closeSignaturePad">×</text>
  </view>
  <view class="modal-content signature-content">
    <view class="signature-checkbox">
      <view class="checkbox {{agreementRead ? 'checked' : ''}}" bindtap="toggleAgreementRead">
        <text class="checkbox-text">✓</text>
      </view>
      <text class="checkbox-label">已阅读</text>
    </view>
    <view class="signature-prompt">请在下方手写签名</view>
    <view class="signature-prompt-container">
      <text class="signature-prompt-text">请在下方手写签名</text>
      <text class="clear-btn" bindtap="clearSignature">清除</text>
    </view>
    <view class="canvas-wrapper">
      <canvas
        id="signatureCanvas"
        class="signature-canvas"
        canvas-id="signatureCanvas"
        width="600"
        height="300"
        bindtouchstart="startSignature"
        bindtouchmove="moveSignature"
        bindtouchend="endSignature"
        disable-scroll="true"
      ></canvas>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="closeSignaturePad">取消</button>
      <button class="modal-btn confirm-btn" bindtap="confirmSignature">签署协议</button>
    </view>
  </view>
</view>