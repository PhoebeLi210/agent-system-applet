.container {
  max-width: 750rpx;
  margin: 0 auto;
  background: linear-gradient(180deg, #f0f8ff 0%, #e0f2fe 30%, rgba(255, 255, 255, 0) 100%);
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.header {
  background-color: #f3f4f6;
  padding: 32rpx;
  padding-top: max(32rpx, env(safe-area-inset-top));
  text-align: center;
  position: relative;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #000;
}

.more-btn {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: #fff;
  transition: all 0.3s ease;
}

.progress-bar {
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 0;
  border-radius: 0;
}

.progress-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.progress-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.progress-icon.active {
  background-color: #3b82f6;
  color: #fff;
  box-shadow: 0 0 0 6rpx rgba(59, 130, 246, 0.15);
}

.progress-icon.inactive {
  background-color: #e2e8f0;
  color: #94a3b8;
}

.progress-icon-text {
  font-size: 28rpx;
  font-weight: 600;
}

.progress-label {
  font-size: 20rpx;
  color: #64748b;
  font-weight: 500;
  white-space: nowrap;
}

.progress-label.active {
  color: #3b82f6;
  font-weight: 600;
}

.progress-line {
  flex: 1;
  height: 4rpx;
  background-color: #e2e8f0;
  position: relative;
  border-radius: 2rpx;
}

.progress-line.active {
  background-color: #3b82f6;
}

.content {
  padding: 32rpx 24rpx 160rpx;
}

.section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #475569;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 24rpx 32rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1e293b;
  transition: all 0.3s ease;
  background-color: #f8fafc;
}

.form-input:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 6rpx rgba(59, 130, 246, 0.1);
  background-color: #fff;
}

.form-input::placeholder {
  color: #94a3b8;
}

.radio-group {
  display: flex;
  gap: 40rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  cursor: pointer;
}

.radio {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #d1d5db;
  border-radius: 50%;
  appearance: none;
  cursor: pointer;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.radio-checked {
  border-color: #3b82f6;
  background-color: #3b82f6;
}

.radio-inner {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: transparent;
  transition: all 0.3s ease;
}

.radio-inner-checked {
  background-color: #fff;
}

.radio-label {
  font-size: 28rpx;
  color: #475569;
  cursor: pointer;
}

.upload-section {
  margin-bottom: 40rpx;
}

.upload-box {
  border: 2rpx dashed #d1d5db;
  border-radius: 16rpx;
  padding: 60rpx;
  text-align: center;
  background-color: #f9fafb;
  position: relative;
  transition: all 0.3s ease;
  min-height: 200rpx;
}

.upload-box:active {
  border-color: #3b82f6;
  background-color: #f1f5f9;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  object-fit: cover;
  position: absolute;
  top: 0;
  left: 0;
}

.upload-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  z-index: 1;
}

.upload-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #dbeafe;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #3b82f6;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.4;
}

.upload-text.required {
  color: #ef4444;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.example-text {
  font-size: 24rpx;
  color: #3b82f6;
  cursor: pointer;
  transition: all 0.3s ease;
}

.example-text:active {
  text-decoration: underline;
}

.next-btn {
  background-color: #3b82f6 !important;
  color: #fff !important;
  border: none !important;
  border-radius: 20rpx !important;
  padding: 28rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  width: calc(100% - 48rpx) !important;
  margin: 40rpx 24rpx 60rpx !important;
  display: block !important;
  cursor: pointer !important;
  transition: all 0.3s ease !important;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.25) !important;
}

.next-btn:active {
  background-color: #2563eb !important;
  transform: translateY(2rpx) !important;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.15) !important;
}

/* 示例图模态框样式 */
.example-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1100;
}

.example-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translateX(-50%) translateY(-50%);
  width: 90%;
  max-width: 680rpx;
  background-color: #fff;
  border-radius: 24rpx;
  z-index: 1101;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.2);
}

.example-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid #f1f5f9;
}

.example-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.example-close {
  background: none;
  border: none;
  font-size: 40rpx;
  color: #64748b;
  cursor: pointer;
  padding: 8rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.example-close:active {
  background-color: #f1f5f9;
  color: #334155;
}

.example-content {
  padding: 32rpx;
}

.example-images {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.example-image {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.example-image-placeholder {
  width: 100%;
  aspect-ratio: 1.5;
  background-color: #f8fafc;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e2e8f0;
}

.example-caption {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
}

/* 银行卡样式 */
.bank-card {
  width: 100%;
  height: 100%;
  background-color: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  padding: 32rpx;
}

.bank-card-header {
  width: 100%;
  display: flex;
  justify-content: flex-start;
  margin-bottom: 32rpx;
}

.bank-card-chip {
  width: 60rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  border-radius: 8rpx;
}

.bank-card-number {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.bank-card-line {
  height: 12rpx;
  background-color: #e2e8f0;
  border-radius: 6rpx;
  width: 100%;
}

.bank-card-line.short {
  width: 70%;
}

.bank-card-line.very-short {
  width: 40%;
}

.bank-card-footer {
  width: 100%;
  display: flex;
  justify-content: flex-end;
}

.bank-card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #475569;
}

/* 账户材料示例图样式 */
.account-material-wrapper {
  width: 100%;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f1f5f9;
}

.account-material-inner {
  width: 80%;
  margin: 40rpx auto;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.account-material-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
}

.account-material-lines {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.account-material-line {
  height: 16rpx;
  background-color: #e2e8f0;
  border-radius: 8rpx;
  width: 100%;
}

/* 银行卡示例图样式 */
.bank-card-wrapper {
  width: 100%;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f1f5f9;
}

.bank-card-inner {
  width: 80%;
  margin: 40rpx auto;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.bank-card-header {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 24rpx;
}

.bank-card-chip {
  width: 60rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  border-radius: 8rpx;
}

.bank-card-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.bank-card-line {
  height: 14rpx;
  background-color: #e2e8f0;
  border-radius: 7rpx;
  width: 100%;
}

.bank-card-footer {
  display: flex;
  justify-content: flex-end;
}

.bank-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
}

/* 地区选择器样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.region-selector-container {
  max-width: 750rpx;
  width: 100%;
  height: 50vh;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  position: fixed;
  bottom: 0;
  left: 0;
  z-index: 1001;
}

.region-selector-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid #f1f5f9;
}

.region-selector-header text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.region-selector-tabs {
  display: flex;
  border-bottom: 2rpx solid #f1f5f9;
}

.region-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
  border-bottom: 4rpx solid transparent;
  cursor: pointer;
  transition: all 0.3s ease;
}

.region-tab.active {
  color: #3b82f6;
  border-bottom: 4rpx solid #3b82f6;
}

.region-selector-content {
  flex: 1;
  overflow-y: auto;
}

.region-list {
  padding: 16rpx;
}

.region-item {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #334155;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.region-item:active {
  background-color: #f1f5f9;
}

.region-item.selected {
  background-color: #dbeafe;
  color: #1d4ed8;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 28rpx;
  background-color: #f8fafc;
}

.search-input::placeholder {
  color: #94a3b8;
}

/* 开户行选择器样式 */
.modal-container {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translateX(-50%) translateY(-50%);
  width: 90%;
  max-width: 680rpx;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 24rpx;
  z-index: 1001;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #e2e8f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.modal-close {
  font-size: 36rpx;
  color: #64748b;
  cursor: pointer;
  transition: color 0.3s ease;
  padding: 8rpx;
}

.modal-content {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.custom-bank-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 28rpx;
  background-color: #f8fafc;
  margin-bottom: 32rpx;
}

.custom-bank-input::placeholder {
  color: #94a3b8;
}

.modal-footer {
  display: flex;
  gap: 40rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.cancel-btn {
  background-color: #f8fafc;
  color: #64748b;
  border: 2rpx solid #e2e8f0;
}

.confirm-btn {
  background-color: #3b82f6;
  color: #fff;
  border: none;
}

.error-message {
  font-size: 24rpx;
  color: #ef4444;
  margin-top: 8rpx;
}

.optional {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: normal;
}

.location-icon {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .container {
    max-width: 100%;
  }
  
  .section {
    padding: 28rpx;
    margin-bottom: 20rpx;
  }
  
  .upload-section {
    gap: 20rpx;
  }
  
  .upload-box {
    height: 170rpx;
    padding: 20rpx 12rpx;
  }
  
  .next-btn {
    width: calc(100% - 40rpx);
    margin: 32rpx 20rpx 48rpx;
  }
  
  .radio-group {
    gap: 32rpx;
  }
}