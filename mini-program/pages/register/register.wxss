.container {
  min-height: 100vh;
  background: linear-gradient(180deg, rgba(239, 246, 255, 0.9) 0%, rgba(219, 234, 254, 0.6) 30%, rgba(241, 245, 249, 0.8) 100%);
  padding-bottom: 120rpx;
}

.header {
  background-color: #f3f4f6;
  padding: 32rpx;
  text-align: center;
  position: relative;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #000;
}

.more-btn {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  color: #1e293b;
  font-size: 28rpx;
}

.progress-bar {
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 0;
  border-radius: 0;
  background-color: #fff;
}

.progress-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.progress-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.progress-icon.active {
  background-color: #3b82f6;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.progress-icon.inactive {
  background-color: #e2e8f0;
  color: #94a3b8;
}

.progress-label {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 500;
  white-space: nowrap;
}

.progress-label.active {
  color: #3b82f6;
  font-weight: 600;
}

.progress-line {
  height: 4rpx;
  flex: 1;
  max-width: 80rpx;
  background-color: #e2e8f0;
}

.progress-line.active {
  background-color: #3b82f6;
}

.content {
  padding: 16rpx 12rpx;
}

.section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
  margin-bottom: 24rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 32rpx;
  background-color: #3b82f6;
  border-radius: 4rpx;
}

.merchant-type-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.radio-group {
  display: flex;
  gap: 40rpx;
  justify-content: flex-end;
  align-items: center;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.radio-item:active {
  transform: scale(0.98);
}

.radio {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #cbd5e1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.radio-checked {
  border-color: #3b82f6;
  background-color: #eff6ff;
}

.radio-inner {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.radio-inner-checked {
  background-color: #3b82f6;
}

.radio-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #334155;
}

.legal-person-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.example-text {
  font-size: 26rpx;
  color: #3b82f6;
  cursor: pointer;
  font-weight: 500;
}

.upload-section {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.upload-box {
  flex: 1;
  height: 180rpx;
  border: 2rpx dashed #cbd5e1;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background-color: #f8fafc;
  transition: all 0.3s ease;
  cursor: pointer;
  position: relative;
}

.upload-box:active {
  border-color: #3b82f6;
  background-color: #f1f5f9;
  transform: scale(0.98);
}

.upload-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #dbeafe;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #3b82f6;
  transition: all 0.3s ease;
}

.upload-icon-text {
  font-size: 60rpx;
  color: #94a3b8;
  line-height: 1;
  font-weight: 300;
}

.upload-text {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  font-weight: 500;
  margin-top: 8rpx;
}

.upload-text.required {
  color: #ef4444;
  font-size: 22rpx;
  font-weight: 500;
}

.uploaded-image {
  max-width: 100%;
  max-height: 300rpx;
  border-radius: 8rpx;
}

.form-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
  transition: all 0.3s ease;
}

.form-group:last-child {
  border-bottom: none;
}

.form-group.left-align {
  display: flex;
  align-items: center;
  padding-left: 16rpx;
  padding-right: 16rpx;
  padding-top: 12rpx;
  padding-bottom: 12rpx;
}

.form-group.left-align > view:first-child {
  width: 200rpx;
  flex-shrink: 0;
}

.form-group.left-align .form-label {
  width: auto;
  display: inline-block;
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #334155;
  font-weight: 500;
  flex-shrink: 0;
}

.form-input {
  font-size: 28rpx;
  color: #64748b;
  border: none;
  outline: none;
  text-align: right;
  background: transparent;
  padding: 8rpx 0;
  width: 400rpx;
}

.form-input.left-align-input {
  text-align: right;
  margin-left: auto;
  width: 280rpx;
}

.date-display {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: right;
  cursor: pointer;
  padding: 8rpx 0;
}

.validity-text {
  font-size: 26rpx;
  color: #eab308;
  cursor: pointer;
  white-space: nowrap;
}

.form-select {
  font-size: 28rpx;
  color: #64748b;
  border: none;
  outline: none;
  text-align: right;
  background: transparent;
  appearance: none;
  padding: 8rpx 0;
  display: block;
  width: 280rpx;
  direction: ltr;
  height: 60rpx;
  line-height: 60rpx;
  white-space: nowrap;
}

.page-spacer {
  height: 80rpx;
}

.next-btn {
  background-color: #3b82f6 !important;
  color: #fff !important;
  border: none !important;
  border-radius: 20rpx !important;
  padding: 28rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  width: calc(100% - 48rpx) !important;
  margin: 40rpx 24rpx 60rpx !important;
  display: block !important;
  cursor: pointer !important;
  transition: all 0.3s ease !important;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.25) !important;
}

.next-btn:active {
  background-color: #2563eb !important;
  transform: translateY(2rpx) !important;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.15) !important;
}

/* 示例图模态框 */
.example-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.example-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  width: 90%;
  max-width: 650rpx;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  z-index: 1101;
  animation: modalFadeIn 0.3s ease-out;
  transform: translate(-50%, -50%);
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.example-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #e2e8f0;
}

.example-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.example-close {
  font-size: 44rpx;
  color: #94a3b8;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.example-close:active {
  background-color: #f1f5f9;
  color: #64748b;
}

.example-content {
  padding: 32rpx;
}

.example-images {
  display: flex;
  gap: 24rpx;
  justify-content: space-around;
}

.example-image {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.example-image-placeholder {
  width: 240rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 2rpx solid #cbd5e1;
}

.id-card-front,
.id-card-back {
  width: 200rpx;
  height: 120rpx;
  background: #fff;
  border-radius: 8rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.id-card-emblem {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  font-size: 40rpx;
  font-weight: 700;
}

.id-avatar {
  width: 60rpx;
  height: 80rpx;
  border-radius: 4rpx;
  background: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.id-lines {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.id-line {
  height: 6rpx;
  background: #e2e8f0;
  border-radius: 3rpx;
}

.id-pattern,
.id-pattern-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  font-weight: 500;
}

.id-pattern {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.id-pattern-text {
  font-size: 10rpx;
  color: #64748b;
  text-align: center;
  font-weight: 500;
}

.example-caption {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  font-weight: 500;
  margin-top: 24rpx;
}

.license-example-wrapper {
  width: 100%;
  border: 2rpx solid #cbd5e1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fff;
}

.license-example-header {
  background-color: #f8fafc;
  border-bottom: 1rpx solid #e2e8f0;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.license-example-content {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.license-line {
  height: 16rpx;
  background-color: #e2e8f0;
  border-radius: 8rpx;
}

.license-example-footer {
  background-color: #f8fafc;
  border-top: 1rpx solid #e2e8f0;
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: flex-end;
}

.license-date {
  font-size: 24rpx;
  color: #64748b;
}

/* 日期选择器样式 */
.date-picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.date-picker-container {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 0;
  width: 100%;
  max-width: 750rpx;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx;
  z-index: 1001;
  box-sizing: border-box;
  overflow: hidden;
}

.date-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #e2e8f0;
}

.date-picker-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.date-picker-close {
  font-size: 36rpx;
  color: #64748b;
  cursor: pointer;
  background: none;
  border: none;
  padding: 8rpx 12rpx;
  line-height: 1;
}

.date-picker-columns {
  display: flex;
  justify-content: space-around;
  height: 400rpx;
}

.date-picker-columns picker-view-column {
  flex: 1;
}

.date-picker-item {
  padding: 0;
  text-align: center;
  font-size: 32rpx;
  color: #64748b;
}

.date-picker-confirm {
  background-color: #3b82f6;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  width: 100%;
  margin-top: 24rpx;
}

.date-picker-confirm:active {
  background-color: #2563eb;
}