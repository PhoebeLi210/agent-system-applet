.date-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.picker-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.picker-btn {
  font-size: 28rpx;
  color: #64748b;
  padding: 8rpx 16rpx;
}

.picker-btn.cancel {
  color: #64748b;
}

.picker-btn.confirm {
  color: #3b82f6;
  font-weight: 600;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.picker-view {
  height: 500rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 28rpx;
  color: #334155;
}