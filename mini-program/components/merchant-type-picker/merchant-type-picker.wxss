.merchant-type-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.picker-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
  flex-shrink: 0;
}

.picker-btn {
  font-size: 28rpx;
  color: #64748b;
  padding: 8rpx 16rpx;
}

.picker-btn.cancel {
  color: #64748b;
}

.picker-btn.confirm {
  color: #3b82f6;
  font-weight: 600;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.picker-content {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.category-list {
  width: 240rpx;
  background-color: #f8fafc;
  border-right: 2rpx solid #f1f5f9;
}

.category-item {
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  color: #64748b;
  border-bottom: 2rpx solid #f1f5f9;
  transition: all 0.3s ease;
}

.category-item.active {
  background-color: #fff;
  color: #3b82f6;
  font-weight: 600;
  border-left: 4rpx solid #3b82f6;
}

.subcategory-list {
  flex: 1;
  overflow-y: auto;
}

.subcategory-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #334155;
  border-bottom: 2rpx solid #f1f5f9;
  transition: all 0.3s ease;
}

.subcategory-item.active {
  background-color: #f0f9ff;
  color: #3b82f6;
  font-weight: 600;
}

.check-icon {
  font-size: 28rpx;
  color: #3b82f6;
}

.empty-tip {
  padding: 64rpx 32rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
}