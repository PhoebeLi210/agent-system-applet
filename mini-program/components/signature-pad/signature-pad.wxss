.signature-pad {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.pad-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.pad-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
  flex-shrink: 0;
}

.pad-btn {
  font-size: 28rpx;
  padding: 8rpx 16rpx;
  transition: all 0.3s ease;
}

.pad-btn.cancel {
  color: #64748b;
}

.pad-btn.clear {
  color: #ef4444;
}

.pad-btn.confirm {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  border: none;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
  width: 100%;
}

.pad-btn.confirm:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.25);
}

.pad-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.pad-content {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.signature-canvas {
  width: 100%;
  height: 400rpx;
  background-color: #f8fafc;
  border: 4rpx dashed #cbd5e1;
  border-radius: 16rpx;
  touch-action: none;
}

.tip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.pad-footer {
  padding: 32rpx;
  border-top: 2rpx solid #f1f5f9;
  flex-shrink: 0;
}