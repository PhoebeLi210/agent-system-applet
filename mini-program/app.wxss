/* 全局样式 */
page {
  --primary-color: #07c160;
  --primary-dark: #06ad56;
  --text-color: #333;
  --text-secondary: #666;
  --text-light: #999;
  --bg-color: #f5f5f5;
  --border-color: #e5e5e5;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', sans-serif;
  background-color: var(--bg-color);
  color: var(--text-color);
}

.container {
  padding: 30rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 标题样式 */
.title {
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
  color: var(--text-color);
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

/* 步骤提示 */
.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
  color: var(--text-color);
}

.step-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 二维码容器 */
.qrcode-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.qrcode-tip {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--text-light);
}

/* 按钮样式 */
.btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin: 20rpx 0;
}

.btn-primary {
  background: var(--primary-color);
  color: #fff;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-primary[disabled] {
  background: #ccc;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

/* 提示信息 */
.tip-box {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #d48806;
  line-height: 1.6;
}

/* 表单样式 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-label .required {
  color: #ff4d4f;
  margin-right: 8rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fff;
}

.form-input:focus {
  border-color: var(--primary-color);
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fff;
}

/* 选择器样式 */
.picker {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fff;
  display: flex;
  align-items: center;
}

.picker-placeholder {
  color: var(--text-light);
}

/* 上传图片 */
.upload-box {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-box:active {
  border-color: var(--primary-color);
  background: #f0f9f0;
}

.upload-icon {
  font-size: 60rpx;
  color: var(--text-light);
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 24rpx;
  color: var(--text-light);
}

.upload-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

/* 成功页面 */
.success-icon {
  width: 160rpx;
  height: 160rpx;
  margin: 60rpx auto 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f6ffed;
  border-radius: 50%;
}

.success-icon text {
  font-size: 100rpx;
  color: var(--primary-color);
}

.success-title {
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20rpx;
  color: var(--text-color);
}

.success-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 60rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 30rpx 0;
}

/* 信息展示 */
.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
}

/* 图标定义 - 使用Unicode安全字符 */
.icon-id-card::before {
  content: "1";
}

.icon-store::before {
  content: "2";
}

.icon-wallet::before {
  content: "3";
}

.icon-percentage::before {
  content: "4";
}

.icon-user::before {
  content: "👤";
}

.icon-building::before {
  content: "🏢";
}

/* 流程指示器图标active状态 - 使用蓝色 */
.progress-icon.active.icon-id-card,
.progress-icon.active.icon-store,
.progress-icon.active.icon-wallet,
.progress-icon.active.icon-percentage {
  background-color: #3b82f6;
  color: #fff;
}

/* 流程指示器图标inactive状态 - 使用灰色 */
.progress-icon.inactive.icon-id-card,
.progress-icon.inactive.icon-store,
.progress-icon.inactive.icon-wallet,
.progress-icon.inactive.icon-percentage {
  background-color: #e2e8f0;
  color: #94a3b8;
}
